# Resend API key (https://resend.com/api-keys) — required for sending email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender must be on a domain verified in Resend (or onboarding@resend.dev for testing)
EMAIL_FROM="AIE Digest <digest@yourdomain.com>"
EMAIL_TO=you@example.com

# AI Engineer channel (@aiDotEngineer)
CHANNEL_ID=UCLKPca3kwwd-B59HNr-_lvA

# Model passed to `claude -p --model ...` (sonnet | opus | haiku | full model id)
CLAUDE_MODEL=sonnet
# Absolute path to the claude binary; leave empty to auto-detect
CLAUDE_BIN=

# --- tunables (defaults shown) ---
# How far back the first run (or a run with no prior success) looks, in hours
LOOKBACK_HOURS=26
# Cap on catch-up after missed days, in hours (168 = 7 days)
MAX_CATCHUP_HOURS=168
# Wait this long for YouTube auto-captions before summarizing without a transcript
CAPTION_GRACE_HOURS=48
# Send a short "no new videos" email on empty days (true/false)
SEND_EMPTY_DIGEST=false
# Email you if a run fails (true/false)
ERROR_EMAILS=true
# Include YouTube Shorts (< 75s) in the digest (true/false)
INCLUDE_SHORTS=false
